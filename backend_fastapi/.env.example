SECRET_KEY=change_me_super_secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
POSTGRES_DSN=postgresql+psycopg://postgres:postgres@localhost:5432/seller_mvp
REDIS_URL=redis://localhost:6379/0
CREDENTIAL_ENCRYPTION_KEY=REPLACE_WITH_FERNET_KEY

# Same-origin reverse proxy mode: keep empty to disable CORS middleware
CORS_ORIGINS=

# If frontend hosted on another origin, set comma-separated list, e.g.:
# CORS_ORIGINS=https://example.com,https://staging.example.com
